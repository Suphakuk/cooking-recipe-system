# ============================================================
#  Backend Environment Variables
# ============================================================

# --- Database (PostgreSQL) ---
# Local example:  postgresql://user:password@localhost:5432/cooking_recipe_db
# Neon example:   postgresql://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/cooking_recipe_db?sslmode=require"

# --- Server ---
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# --- Frontend origin(s) allowed by CORS ---
# You can list multiple, comma-separated (local + deployed):
# CLIENT_URL="http://localhost:3000,https://your-app.vercel.app"
CLIENT_URL="http://localhost:3000"

# --- JWT secrets (CHANGE THESE to long random strings in production!) ---
JWT_ACCESS_SECRET="change_me_to_a_long_random_string"
JWT_REFRESH_SECRET="change_me_to_another_long_random_string"
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Uploads (images are stored as base64 in the DB; this only caps file size) ---
MAX_FILE_SIZE_MB=5

# --- Mock AI ---
MOCK_AI_ENABLED=true
